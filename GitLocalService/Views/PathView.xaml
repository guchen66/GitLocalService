<UserControl x:Class="GitLocalService.Views.PathView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <StackPanel>
            <TextBlock Text="How would you like to use Git from the command line?" 
                       FontSize="14" 
                       Foreground="#24292E"
                       Margin="0,0,0,15" />
            
            <Border Background="#FFFFFF" BorderBrush="#D1D9E0" BorderThickness="1" CornerRadius="4">
                <StackPanel Margin="10">
                    <StackPanel Margin="0,5,0,0">
                        <RadioButton Content="Git Bash only" 
                                     IsChecked="{Binding PathOption, Converter={StaticResource StringEqualsConverter}, ConverterParameter=GitBashOnly}"
                                     GroupName="Path"
                                     FontSize="13"
                                     Foreground="#24292E" />
                        <TextBlock Text="This is the safest choice if you don't understand the other options." 
                                   FontSize="11"
                                   Foreground="#6E7681"
                                   Margin="20,2,0,0" />
                    </StackPanel>
                    <StackPanel Margin="0,5,0,0">
                        <RadioButton Content="Git from the command line and also from 3rd-party software" 
                                     IsChecked="{Binding PathOption, Converter={StaticResource StringEqualsConverter}, ConverterParameter=CmdAndThirdParty}"
                                     GroupName="Path"
                                     FontSize="13"
                                     Foreground="#24292E" />
                        <TextBlock Text="Recommended choice for most users." 
                                   FontSize="11"
                                   Foreground="#6E7681"
                                   Margin="20,2,0,0" />
                    </StackPanel>
                    <StackPanel Margin="0,5,0,0">
                        <RadioButton Content="Use Git and optional Unix tools from the Command Prompt" 
                                     IsChecked="{Binding PathOption, Converter={StaticResource StringEqualsConverter}, ConverterParameter=CmdAndUnixTools}"
                                     GroupName="Path"
                                     FontSize="13"
                                     Foreground="#24292E" />
                        <TextBlock Text="Both Git and Unix tools will be available from the Command Prompt." 
                                   FontSize="11"
                                   Foreground="#6E7681"
                                   Margin="20,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>