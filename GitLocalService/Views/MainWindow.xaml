<Window
    x:Class="GitLocalService.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:prism="http://prismlibrary.com/"
    Title="Git Setup"
    Width="800"
    Height="600"
    prism:ViewModelLocator.AutoWireViewModel="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#24292E">
            <StackPanel
                Margin="20,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Rectangle
                    Width="48"
                    Height="48"
                    Margin="0,0,15,0">
                    <Rectangle.Fill>
                        <DrawingBrush>
                            <DrawingBrush.Drawing>
                                <GeometryDrawing>
                                    <GeometryDrawing.Geometry>
                                        <PathGeometry>
                                            <PathFigure StartPoint="24,4">
                                                <ArcSegment
                                                    Point="24,44"
                                                    Size="20,20"
                                                    SweepDirection="Clockwise" />
                                                <ArcSegment
                                                    Point="24,4"
                                                    Size="20,20"
                                                    SweepDirection="Clockwise" />
                                            </PathFigure>
                                            <PathFigure StartPoint="24,14">
                                                <ArcSegment
                                                    Point="24,34"
                                                    Size="10,10"
                                                    SweepDirection="Clockwise" />
                                                <ArcSegment
                                                    Point="24,14"
                                                    Size="10,10"
                                                    SweepDirection="Clockwise" />
                                            </PathFigure>
                                            <PathFigure StartPoint="24,4">
                                                <LineSegment Point="24,14" />
                                                <LineSegment Point="34,24" />
                                                <LineSegment Point="24,34" />
                                                <LineSegment Point="14,24" />
                                                <LineSegment Point="24,14" />
                                            </PathFigure>
                                        </PathGeometry>
                                    </GeometryDrawing.Geometry>
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#F05032" Thickness="3" />
                                    </GeometryDrawing.Pen>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Git Setup" />
                    <TextBlock
                        FontSize="14"
                        Foreground="#8B949E"
                        Text="{Binding Title}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ContentControl
            Grid.Row="1"
            Margin="20"
            prism:RegionManager.RegionName="ContentRegion" />

        <Border
            Grid.Row="2"
            Background="#F6F8FA"
            BorderBrush="#D1D9E0"
            BorderThickness="1,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ProgressBar
                        Width="200"
                        Height="24"
                        Margin="0,0,10,0"
                        Background="#E1E4E8"
                        Foreground="#F05032"
                        Maximum="100"
                        Value="{Binding ProgressValue}" />
                    <TextBlock
                        FontSize="13"
                        Foreground="#6E7681"
                        Text="{Binding ProgressText}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="80"
                    Height="30"
                    Command="{Binding PreviousCommand}"
                    Content="&lt; Back"
                    IsEnabled="{Binding CanGoPrevious}" />

                <Button
                    Grid.Column="3"
                    Width="80"
                    Height="30"
                    Command="{Binding NextCommand}"
                    Content="{Binding NextButtonContent}"
                    IsEnabled="{Binding CanGoNext}" />

                <Button
                    Grid.Column="5"
                    Width="80"
                    Height="30"
                    Command="{Binding CancelCommand}"
                    Content="Cancel" />
            </Grid>
        </Border>
    </Grid>
</Window>