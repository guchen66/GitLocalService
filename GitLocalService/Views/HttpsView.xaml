<UserControl x:Class="GitLocalService.Views.HttpsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <StackPanel>
            <TextBlock Text="Which backend do you want to use for HTTPS transport?" 
                       FontSize="14" 
                       Foreground="#24292E"
                       Margin="0,0,0,15" />
            
            <Border Background="#FFFFFF" BorderBrush="#D1D9E0" BorderThickness="1" CornerRadius="4">
                <StackPanel Margin="10">
                    <RadioButton Content="Use the OpenSSL library" 
                                 IsChecked="{Binding HttpsBackend, Converter={StaticResource StringEqualsConverter}, ConverterParameter=OpenSSL}"
                                 GroupName="HTTPS"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use native Windows Secure Channel library" 
                                 IsChecked="{Binding HttpsBackend, Converter={StaticResource StringEqualsConverter}, ConverterParameter=SecureChannel}"
                                 GroupName="HTTPS"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>