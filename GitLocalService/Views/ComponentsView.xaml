<UserControl x:Class="GitLocalService.Views.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <StackPanel>
            <TextBlock Text="Select the components you want to install." 
                       FontSize="14" 
                       Foreground="#24292E"
                       Margin="0,0,0,15" />
            
            <Border Background="#FFFFFF" BorderBrush="#D1D9E0" BorderThickness="1" CornerRadius="4" Height="350">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <ItemsControl ItemsSource="{Binding Components}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <CheckBox Content="{Binding DisplayName}" 
                                              IsChecked="{Binding Checked}"
                                              FontSize="14"
                                              Foreground="#24292E"
                                              Margin="0,5,0,0" />
                                    <ItemsControl ItemsSource="{Binding Children}" Margin="25,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}" 
                                                          IsChecked="{Binding Checked}"
                                                          FontSize="13"
                                                          Foreground="#6E7681"
                                                          Margin="0,3,0,0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>