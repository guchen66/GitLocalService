<UserControl x:Class="GitLocalService.Views.ExtraOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <StackPanel>
            <TextBlock Text="Configure additional options" 
                       FontSize="14" 
                       Foreground="#24292E"
                       Margin="0,0,0,15" />
            
            <Border Background="#FFFFFF" BorderBrush="#D1D9E0" BorderThickness="1" CornerRadius="4">
                <StackPanel Margin="10">
                    <CheckBox Content="Enable file system caching" 
                              IsChecked="{Binding EnableFileSystemCaching}"
                              FontSize="13"
                              Foreground="#24292E"
                              Margin="0,5,0,0" />
                    <CheckBox Content="Enable symbolic links" 
                              IsChecked="{Binding EnableSymbolicLinks}"
                              FontSize="13"
                              Foreground="#24292E"
                              Margin="0,5,0,0" />
                    <CheckBox Content="Enable pseudo console support" 
                              IsChecked="{Binding EnablePseudoConsole}"
                              FontSize="13"
                              Foreground="#24292E"
                              Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>