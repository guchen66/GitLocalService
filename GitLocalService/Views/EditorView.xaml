<UserControl x:Class="GitLocalService.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <StackPanel>
            <TextBlock Text="Which editor would you like Git to use by default?" 
                       FontSize="14" 
                       Foreground="#24292E"
                       Margin="0,0,0,15" />
            
            <Border Background="#FFFFFF" BorderBrush="#D1D9E0" BorderThickness="1" CornerRadius="4">
                <StackPanel Margin="10">
                    <RadioButton Content="Use Vim as Git's default editor" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Vim}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use Notepad as default editor" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Notepad}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use Visual Studio Code" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=VSCode}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use Notepad++" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Notepad++}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use Sublime Text" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=SublimeText}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use Atom" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Atom}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use Emacs" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Emacs}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                    <RadioButton Content="Use Nano" 
                                 IsChecked="{Binding DefaultEditor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Nano}"
                                 GroupName="Editor"
                                 FontSize="13"
                                 Foreground="#24292E"
                                 Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>