<UserControl x:Class="GitLocalService.Views.InstallingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Installing Git..." 
                       FontSize="18" 
                       Foreground="#24292E"
                       TextAlignment="Center"
                       Margin="0,0,0,20" />
            
            <Border Background="#FFFFFF" BorderBrush="#D1D9E0" BorderThickness="1" CornerRadius="4" Padding="20">
                <StackPanel>
                    <ProgressBar Value="{Binding Progress}" 
                                  Maximum="100" 
                                  Height="20" 
                                  Margin="0,0,0,15"
                                  Background="#F0F0F0"
                                  Foreground="#F05032" />
                    
                    <TextBlock Text="{Binding CurrentAction}" 
                               FontSize="13" 
                               Foreground="#6E7681"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>