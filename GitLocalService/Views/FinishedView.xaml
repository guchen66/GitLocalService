<UserControl x:Class="GitLocalService.Views.FinishedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Git has been successfully installed on your computer." 
                       FontSize="18" 
                       Foreground="#24292E"
                       TextAlignment="Center"
                       Margin="0,0,0,30" />
            
            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,30">
                <CheckBox Content="Launch Git Bash" 
                          IsChecked="{Binding LaunchGitBash}"
                          FontSize="14"
                          Foreground="#24292E"
                          Margin="0,5,0,0" />
                <CheckBox Content="View Release Notes" 
                          IsChecked="{Binding ViewReleaseNotes}"
                          FontSize="14"
                          Foreground="#24292E"
                          Margin="0,5,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>